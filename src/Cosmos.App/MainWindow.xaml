<Window
    x:Class="Cosmos.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border x:Name="TitleBar" Grid.Row="0" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">
            <Grid Padding="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="Cosmos PDF Editor" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - Page Thumbnails -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Pages" Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="16,12" FontWeight="SemiBold"/>

                    <ListView x:Name="PageThumbnails" Grid.Row="1" Padding="8"
                              ItemsSource="{x:Bind _viewModel.Pages, Mode=OneWay}"
                              SelectionChanged="PageThumbnails_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="4" Margin="4">
                                    <Grid Width="120" Height="160">
                                        <Image Source="{Binding ThumbnailImage}" Stretch="Uniform"/>
                                        <TextBlock Text="{Binding PageNumber}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Main Document View -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <CommandBar Grid.Row="0" Background="Transparent" IsOpen="False" DefaultLabelPosition="Right">
                    <AppBarButton Icon="OpenFile" Label="Open" Click="OpenFile_Click"/>
                    <AppBarButton Icon="Save" Label="Save" Click="SaveFile_Click"/>
                    <AppBarSeparator/>
                    <AppBarButton Icon="ZoomIn" Label="Zoom In" Command="{x:Bind _viewModel.ZoomInCommand}"/>
                    <AppBarButton Icon="ZoomOut" Label="Zoom Out" Command="{x:Bind _viewModel.ZoomOutCommand}"/>
                    <AppBarSeparator/>
                    <AppBarButton Icon="Previous" Label="Previous" Command="{x:Bind _viewModel.PreviousPageCommand}"/>
                    <AppBarButton Icon="Next" Label="Next" Command="{x:Bind _viewModel.NextPageCommand}"/>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton Icon="Setting" Label="Settings"/>
                        <AppBarButton Icon="Help" Label="Help"/>
                    </CommandBar.SecondaryCommands>
                </CommandBar>

                <!-- Document Canvas -->
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ZoomMode="Enabled"
                              IsTabStop="True"
                              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                              KeyDown="DocumentCanvas_KeyDown">
                    <Grid x:Name="DocumentCanvas"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Padding="40">
                        <!-- PDF page rendered here -->
                        <Border Background="White"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Image x:Name="PageImage"
                                   Source="{x:Bind _viewModel.CurrentPageImage, Mode=OneWay}"
                                   Stretch="Uniform"/>
                        </Border>
                        <!-- Fallback text when no document is loaded -->
                        <TextBlock Text="Open a PDF file to begin"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </ScrollViewer>

                <!-- Status Bar -->
                <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <Grid Padding="16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource CaptionTextBlockStyle}">
                            <Run Text="Page"/>
                            <Run Text="{x:Bind _viewModel.CurrentPage, Mode=OneWay}"/>
                            <Run Text="of"/>
                            <Run Text="{x:Bind _viewModel.TotalPages, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}">
                            <Run Text="Zoom:"/>
                            <Run Text="{x:Bind _viewModel.ZoomLevel, Mode=OneWay}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
